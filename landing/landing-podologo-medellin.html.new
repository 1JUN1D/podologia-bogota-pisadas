<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Podólogo Medellín | Clínica Podológica Particular | DALIA OSORIO</title>
  <meta name="description" content="Podólogo en Medellín — clínica podológica particular, atención a domicilio, sin EPS. Belén, Laureles, Norte, Envigado. Agenda por WhatsApp hoy. DALIA OSORIO.">
  <link rel="stylesheet" href="landing.css">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-G39DRE1X2F"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-G39DRE1X2F');
  </script>

  <style>
    /* Zone pills */
    .zones-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 2rem;
    }
    .zone-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: var(--white);
      border: 1.5px solid var(--teal-mid);
      color: var(--teal-dark);
      padding: 8px 18px;
      border-radius: 50px;
      font-size: 0.83rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      transition: var(--transition);
    }
    .zone-pill:hover {
      background: var(--teal);
      color: white;
      border-color: var(--teal);
    }
    .zone-pill svg { flex-shrink: 0; }

    /* Services list */
    .services-compact {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    @media(max-width:600px){ .services-compact { grid-template-columns: 1fr; } }

    .service-pill {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--off-white);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 14px 18px;
      transition: var(--transition);
    }
    .service-pill:hover {
      border-color: var(--teal-mid);
      box-shadow: var(--shadow-xs);
      transform: translateX(4px);
    }
    .service-pill__icon {
      width: 38px;
      height: 38px;
      background: var(--teal-light);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .service-pill__text strong {
      display: block;
      font-size: 0.9rem;
      color: var(--text-dark);
      font-weight: 600;
      margin-bottom: 1px;
    }
    .service-pill__text span {
      font-size: 0.8rem;
      color: var(--text-light);
    }

    /* Pricing section */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media(max-width: 900px){ .pricing-grid { grid-template-columns: repeat(2,1fr); } }
    @media(max-width: 560px){ .pricing-grid { grid-template-columns: 1fr; } }

    .price-card {
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-md);
      padding: 28px 24px 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
    }
    .price-card:hover {
      border-color: var(--teal);
      box-shadow: var(--shadow-md);
      transform: translateY(-5px);
    }
    .price-card__badge {
      position: absolute;
      top: 14px; right: 14px;
      background: var(--teal-light);
      color: var(--teal-dark);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 50px;
    }
    .price-card__badge--domicilio {
      background: #FFF0E9;
      color: var(--accent);
    }
    .price-card__icon {
      font-size: 1.8rem;
      line-height: 1;
    }
    .price-card__name {
      font-family: var(--font-display);
      font-size: 1.15rem;
      color: var(--text-dark);
      font-weight: 600;
      line-height: 1.2;
      margin-top: 4px;
    }
    .price-card__desc {
      font-size: 0.86rem;
      color: var(--text-mid);
      line-height: 1.65;
      flex: 1;
    }
    .price-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 8px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 10px;
    }
    .price-card__price {
      font-family: var(--font-display);
      font-size: 1.55rem;
      color: var(--teal-deep);
      font-weight: 700;
      line-height: 1;
    }
    .price-card__price small {
      font-size: 0.75rem;
      color: var(--text-light);
      font-family: var(--font-body);
      font-weight: 400;
      display: block;
      margin-top: 2px;
    }
    .price-card__cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #25D366;
      color: white;
      padding: 8px 16px;
      border-radius: 50px;
      font-size: 0.8rem;
      font-weight: 600;
      transition: var(--transition);
      white-space: nowrap;
    }
    .price-card__cta:hover {
      background: #20b858;
      transform: scale(1.03);
    }
    .pricing-note {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.85rem;
      color: var(--text-light);
    }
    .pricing-note a {
      color: var(--teal-dark);
      font-weight: 600;
    }

    /* Domicilio highlight */
    .domicilio-card {
      background: linear-gradient(135deg, var(--teal-deep), #004a55);
      color: white;
      border-radius: var(--radius-lg);
      padding: 52px 48px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .domicilio-card::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(0,184,212,0.2), transparent 70%);
    }
    .domicilio-card h3 {
      font-family: var(--font-display);
      font-size: 2rem;
      margin-bottom: 1rem;
      line-height: 1.15;
    }
    .domicilio-card p {
      color: rgba(255,255,255,0.75);
      font-size: 1rem;
      line-height: 1.7;
      margin-bottom: 1.8rem;
    }
    @media(max-width:760px){
      .domicilio-card {
        grid-template-columns: 1fr;
        padding: 36px 28px;
      }
    }
  </style>

<link rel="shortcut icon" href="/assets/logo.webp" type="image/x-icon">


